# Set to true to skip Atlas/local MongoDB and use an in-memory database
USE_MEMORY_DB=false
MONGODB_URI=mongodb://127.0.0.1:27017/nagarik-palika
# For Atlas, URL-encode special chars in credentials (e.g. @ in email → %40):
# mongodb+srv://user%40example.com:password@cluster.mongodb.net/nagarik-palika
JWT_SECRET=change-this-to-a-long-random-secret-in-production
ADMIN_EMAIL=admin@nagarikpalika.gov.np
ADMIN_PASSWORD=Admin@123
PORT=4000
FRONTEND_URL=http://localhost:3000

# Google OAuth (citizen & advocate sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# eSewa (UAT/sandbox)
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_VERIFY_URL=https://uat.esewa.com.np/api/epay/transaction/status/

# Khalti (test keys)
KHALTI_PUBLIC_KEY=test_public_key_dc74e0fd57cb46c19d64e33b256af0
KHALTI_SECRET_KEY=test_secret_key

# Dev: skip real payment gateways
ALLOW_DEV_PAYMENT=true

# Optional: override bundled reference JSON directory (default: ./data)
# DATA_DIR=./data

# Cron endpoint secret (POST /internal/consultations/open-pool)
CRON_SECRET=dev-cron-secret
